.env
.venv/
__pycache__/
*.pyc
pytest-cache-files-*/
.DS_Store

# Editor / IDE configs (local preference, not shared)
.cursorrules
.kiro/
.opencode.json
.windsurfrules

# Local diagnostic / one-shot scripts (kept out of CI)
scripts/sync_env_to_github_secrets.py

# Added by code-review-graph
.code-review-graph/

# User-specific MCP config (absolute binary paths)
.mcp.json

# Local Claude Code settings (per-user)
.claude/settings.local.json

# Runtime artifacts from scraper runs
live_test.log
debug_dom*.txt
error_*.png

# Per-run data artifacts (code lives in-repo; data does not).
# `results/latest/` IS tracked — it's the dashboard's source of truth and
# needs to be in git so Streamlit Cloud picks up fresh data on every push.
# Only the staging + history runs are ignored (audit trail, written every
# scrape, would balloon the repo).
results/staging/
results/history/
results/latest/INVALID_RUN.md
